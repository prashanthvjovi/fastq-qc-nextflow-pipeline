params {
    input  = "${projectDir}/data/*.fastq"
    outdir = "${projectDir}/results"
}

docker.enabled = true

process {
    executor = 'local'

    withName: FASTQC {
        cpus = 1
        memory = '1 GB'
    }

    withName: MULTIQC {
        cpus = 1
        memory = '1 GB'
    }
}
report {
    enabled = true
    file = "${params.outdir}/pipeline-report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline-timeline.html"
    overwrite = true
}
